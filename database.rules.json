{
  // Standard: alles gesperrt. Nur die Pfade unten sind offen, und auch die nur
  // fuer (anonym) angemeldete Clients (auth != null). Das blockt direkte
  // REST-Zugriffe ohne Token, sobald das Repo oeffentlich ist.
  "rules": {
    ".read": false,
    ".write": false,

    "whiteboard": {
      "sessions": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren()"
        }
      }
    },

    "memory": {
      "games": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren()"
        }
      },
      "scores": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$id": {
          ".validate": "newData.hasChildren(['winnerName', 'finishedAt'])"
        }
      }
    },

    "connect4": {
      "games": {
        "$code": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".validate": "newData.hasChildren()"
        }
      }
    },

